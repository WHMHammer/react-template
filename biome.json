{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "esbuild-scripts/**",
      "src/**",
      "tests/**",
      "*.json",
      "!package-lock.json",
      "*.ts"
    ],
    "ignoreUnknown": true
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": "info",
      "correctness": "error",
      "performance": "info",
      "security": "error",
      "style": "info",
      "suspicious": "error"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true,
      "source": {
        "recommended": true
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "attributePosition": "multiline",
      "operatorLinebreak": "before"
    }
  },
  "overrides": [
    {
      "includes": ["**"],
      "linter": {
        "rules": {
          "style": {
            "noJsxLiterals": "off"
          }
        }
      }
    }
  ]
}
